{
  "name": "open-cockpit",
  "version": "0.1.3",
  "description": "Session cockpit for Claude Code",
  "main": "src/main.js",
  "scripts": {
    "build": "esbuild src/renderer.js --bundle --outfile=dist/renderer.js --platform=browser --format=iife",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron . --dev",
    "dev:own-pool": "npm run build && electron . --dev --own-pool",
    "prepare": "git config core.hooksPath .githooks",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.16",
    "@lezer/highlight": "^1.2.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "^6.0.0",
    "codemirror": "^6.0.2",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-rebuild": "^3.2.9",
    "esbuild": "^0.27.3",
    "vitest": "^4.0.18"
  }
}
